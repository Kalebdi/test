<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0, user-scalable=yes, viewport-fit=cover" />
    <meta http-equiv="X-Content-Type-Options" content="nosniff" />
    <meta http-equiv="X-Frame-Options" content="DENY" />
    <meta http-equiv="X-XSS-Protection" content="1; mode=block" />
    <meta name="referrer" content="strict-origin-when-cross-origin" />
    <meta http-equiv="Content-Security-Policy" content="default-src 'self' https: data:; script-src 'self' 'unsafe-inline' https://cdn.tailwindcss.com https://cdnjs.cloudflare.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdnjs.cloudflare.com; font-src 'self' https://fonts.gstatic.com https://cdnjs.cloudflare.com; img-src 'self' data: https:; connect-src 'self' https:;" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="theme-color" content="#050508" />
    <title>Dardcor AI</title>
    <link rel="icon" href="/logo.png" />
    <link rel="manifest" href="/manifest.json" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
    <style>
      :root { --bg-dark: #050508; }
      html, body {
        height: 100%; width: 100%; margin: 0; padding: 0; overflow: hidden;
        background-color: var(--bg-dark); font-family: "Inter", sans-serif;
        position: fixed; inset: 0; -webkit-tap-highlight-color: transparent;
      }
      .scrollbar-hide::-webkit-scrollbar { display: none; }
      .scrollbar-hide { -ms-overflow-style: none; scrollbar-width: none; }
      @keyframes orbit-1 { 0% { transform: rotate3d(1, 1, 1, 0deg); } 100% { transform: rotate3d(1, 1, 1, 360deg); } }
      @keyframes orbit-2 { 0% { transform: rotate3d(1, -1, 1, 0deg); } 100% { transform: rotate3d(1, -1, 1, 360deg); } }
      @keyframes star-twinkle { 0%, 100% { opacity: 0.3; transform: scale(0.5); } 50% { opacity: 1; transform: scale(1.2); } }
      .animate-orbit-1 { animation: orbit-1 6s linear infinite; }
      .animate-orbit-2 { animation: orbit-2 7s linear infinite; }
      .animate-star { animation: star-twinkle 3s ease-in-out infinite; }
      .star { position: absolute; background: white; border-radius: 50%; }
      /* Glow Effect on Focus */
      .input-container:focus-within {
        border-color: rgba(168, 85, 247, 0.6);
        box-shadow: 0 0 20px rgba(88, 28, 135, 0.3);
      }
    </style>
  </head>
  <body class="bg-[#050508] text-white font-sans h-dvh flex overflow-hidden">
    <div id="overlay" class="fixed inset-0 bg-black/80 hidden z-40 backdrop-blur-sm lg:hidden"></div>
    
    <aside id="sidebar" class="fixed inset-y-0 left-0 w-72 bg-[#0a0a12] border-r border-purple-900/20 flex flex-col transform -translate-x-full z-50 transition-transform duration-300 shadow-2xl">
      <div class="h-16 shrink-0 flex items-center px-4 border-b border-white/10 bg-[#0a0a12]">
        <span class="font-bold text-lg text-purple-400 flex items-center gap-3">
            <img src="/logo.png" class="w-7 h-7 rounded-full" /> Dardcor <span class="text-white">AI</span>
        </span>
      </div>
      <div class="flex-1 overflow-y-auto p-4 scrollbar-hide" id="chat-history">
        <p class="text-xs text-gray-500 text-center mt-10">Belum ada riwayat percakapan.</p>
      </div>
    </aside>

    <main id="content" class="flex-1 flex flex-col min-w-0 bg-[#050508] relative h-full">
      <div class="absolute inset-0 pointer-events-none overflow-hidden">
        <div class="star w-1 h-1 top-1/4 right-1/4 animate-star"></div>
        <div class="star w-0.5 h-0.5 bottom-1/3 left-1/3 animate-star" style="animation-delay: 2s"></div>
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[500px] h-[500px] bg-purple-900/10 rounded-full blur-[100px]"></div>
      </div>

      <header class="h-16 shrink-0 flex items-center px-4 border-b border-purple-900/20 bg-[#050508]/80 backdrop-blur-md z-30 justify-between">
        <button id="toggle-sidebar-btn" class="text-gray-400 p-2 hover:text-white transition-colors">
          <i class="fas fa-bars text-xl"></i>
        </button>
        <div class="flex items-center gap-2">
          <a href="/dardcor" class="px-3 py-1.5 text-xs border border-purple-800/50 rounded-lg text-purple-200 hover:bg-purple-900/20 transition-all">Login</a>
          <button id="pwa-install-btn" class="px-3 py-1.5 text-xs bg-purple-900/40 border border-purple-500/50 rounded-lg text-white">Download App</button>
        </div>
      </header>

      <section id="chat-container" class="flex-1 overflow-y-auto scrollbar-hide relative z-10 flex flex-col items-center pt-8">
        <div class="w-full max-w-4xl mx-auto px-4 flex flex-col items-center mb-10">
          <div class="relative w-32 h-32 flex items-center justify-center mb-6">
            <div class="absolute inset-0 bg-purple-900/30 rounded-full blur-2xl"></div>
            <div class="absolute w-[120%] h-[120%] rounded-full border border-purple-500/40 animate-orbit-1"></div>
            <img src="/logo.png" alt="Logo" class="relative w-20 h-20 object-cover z-10" />
          </div>
          <h2 class="text-3xl font-bold text-white tracking-tight">Dardcor AI</h2>
          <p class="text-purple-300/60 text-sm mt-2 font-light">Eksplorasi Tanpa Batas</p>
        </div>
        
        <div id="messages-wrapper" class="w-full max-w-3xl px-4 space-y-6 pb-20"></div>
      </section>

      <footer class="shrink-0 relative z-20 w-full bg-[#050508] p-4">
  <div class="w-full max-w-3xl mx-auto relative safe-pb">
    <div id="file-preview-container" class="flex flex-wrap gap-2 mb-2 hidden"></div>
    
    <div class="bg-[#0e0e14] border border-purple-900/40 rounded-[1.5rem] p-3 shadow-[0_0_25px_rgba(88,28,135,0.15)] relative flex flex-col transition-all">
      
      <textarea id="message-input" rows="1" class="w-full bg-transparent resize-none outline-none text-purple-100 text-sm md:text-base placeholder:text-purple-500/40 px-2 mb-2 font-light max-h-32 overflow-y-auto scrollbar-hide" placeholder="Tanya Dardcor AI..."></textarea>
      
      <div class="flex justify-between items-center mt-1 gap-2">
        <div class="flex items-center gap-2">
          <button id="file-upload-btn" type="button" class="text-purple-500 hover:text-purple-300 transition-colors p-2 cursor-pointer rounded-full hover:bg-purple-900/20">
            <i class="fas fa-paperclip text-lg"></i>
          </button>
          <input type="file" id="file-upload" class="hidden" multiple>

          <div class="relative">
            <button id="tools-btn" type="button" class="flex items-center gap-1.5 px-3 py-1.5 rounded-full border border-purple-800/30 bg-purple-900/10 text-[11px] md:text-xs font-medium text-purple-400 hover:text-white hover:bg-purple-900/40 transition-all">
              <i class="fas fa-cog"></i> <span>Tools</span>
            </button>
          </div>
        </div>

        <div class="flex items-center gap-3 pr-1">
          <button id="mic-btn" type="button" class="text-purple-500 hover:text-white transition-colors p-1 cursor-pointer">
            <i class="fas fa-microphone text-lg"></i>
          </button>
          
          <button id="send-btn" type="button" class="w-9 h-9 rounded-full bg-purple-600 flex items-center justify-center text-white hover:bg-purple-500 transition-all shadow-lg cursor-pointer">
            <i id="send-icon" class="fas fa-paper-plane text-xs"></i>
          </button>
        </div>
      </div>
    </div>
    <div class="text-center mt-2 text-[10px] text-purple-500/30">Dardcor AI V1.5.0.9 - Guest Access Enabled</div>
  </div>
</footer>
    </main>

    <script src="/js/index.js"></script>
  </body>
</html>
